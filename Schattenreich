// ─── SPEAKING TRIAL ───────────────────────────────────────────
function SpeakingTrial({ prompts, onComplete }) {
  const [currentIdx, setCurrentIdx] = React.useState(0);
  const [isRecording, setIsRecording] = React.useState(false);
  const [transcript, setTranscript] = React.useState('');
  const [feedback, setFeedback] = React.useState(null);
  const [score, setScore] = React.useState(0);
  const [unsupported, setUnsupported] = React.useState(false);
  const recognitionRef = React.useRef(null);
  const timeoutRef = React.useRef(null);

  const prompt = prompts[currentIdx];

  const startRecording = () => {
    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SR) { setUnsupported(true); return; }
    const rec = new SR();
    rec.lang = 'de-DE';
    rec.interimResults = false;
    rec.maxAlternatives = 1;
    recognitionRef.current = rec;
    rec.onresult = e => {
      clearTimeout(timeoutRef.current);
      const said = e.results[0][0].transcript;
      setTranscript(said);
      evaluateSpeech(said, prompt);
      setIsRecording(false);
    };
    rec.onerror = () => { setIsRecording(false); };
    rec.onend = () => setIsRecording(false);
    rec.start();
    setIsRecording(true);
    setTranscript('');
    setFeedback(null);
    timeoutRef.current = setTimeout(() => {
      if (recognitionRef.current) recognitionRef.current.stop();
      setIsRecording(false);
      setFeedback({ similarity: 0, matched: [], missed: prompt.split(/\s+/), message: "Zeit abgelaufen – bitte erneut versuchen." });
    }, 10000);
  };

  const stopRecording = () => {
    clearTimeout(timeoutRef.current);
    recognitionRef.current?.stop();
    setIsRecording(false);
  };

  const evaluateSpeech = (said, pr) => {
    const norm = s => s.toLowerCase().replace(/[.,!?;:]/g, '').trim();
    const sw = norm(said).split(/\s+/);
    const pw = norm(pr).split(/\s+/);
    const matched = pw.filter(w => sw.includes(w));
    const missed = pw.filter(w => !sw.includes(w));
    const sim = matched.length / pw.length;
    setFeedback({ similarity: sim, matched, missed });
    setScore(s => s + Math.round(sim * 30));
  };

  const next = () => {
    if (currentIdx < prompts.length - 1) {
      setCurrentIdx(c => c + 1);
      setTranscript('');
      setFeedback(null);
    } else {
      confetti({ particleCount: 80, spread: 60, origin: { y: 0.6 }, colors: ['#FFD700', '#F5E6D3'] });
      onComplete(score, Math.floor(score / 10));
    }
  };

  return h('div', null,
    h('div', { style: { display: 'flex', justifyContent: 'space-between', marginBottom: '1.5rem', fontSize: '0.875rem' } },
      h('span', { style: { color: '#7B8CA8' } }, `Prompt ${currentIdx+1}/${prompts.length}`),
      h('span', { style: { color: '#FFD700' } }, `Score: ${score}`)
    ),
    h('div', { style: { background: 'rgba(10,0,32,0.5)', border: '1px solid rgba(255,215,0,0.2)', borderRadius: '0.75rem', padding: '1.25rem', marginBottom: '1.5rem' } },
      h('p', { style: { fontSize: '0.75rem', color: '#7B8CA8', textTransform: 'uppercase', letterSpacing: '0.05em', marginBottom: '0.5rem' } }, 'Sprich diesen Satz:'),
      h('div', { style: { display: 'flex', alignItems: 'center', gap: '0.75rem' } },
        h('p', { style: { color: '#F5E6D3', fontSize: '1.125rem', flex: 1, fontStyle: 'italic', fontFamily: "'EB Garamond',serif" } }, prompt),
        h('button', { onClick: () => speak(prompt), style: { padding: '0.5rem', background: 'none', border: 'none', cursor: 'pointer', color: '#FFD700', flexShrink: 0 } }, h(Volume2, { size: 20 }))
      )
    ),
    unsupported && h('div', { style: { background: 'rgba(127,29,29,0.2)', border: '1px solid rgba(239,68,68,0.3)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '1rem', textAlign: 'center' } },
      h('p', { style: { color: '#fca5a5', fontSize: '0.875rem' } }, 'Spracherkennung wird in diesem Browser nicht unterstützt. Bitte Chrome verwenden.')
    ),
    !feedback && h('div', { style: { display: 'flex', justifyContent: 'center', marginBottom: '1.5rem' } },
      h('button', { onClick: isRecording ? stopRecording : startRecording, style: { width: '5rem', height: '5rem', borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center', cursor: 'pointer', border: '2px solid', borderColor: isRecording ? '#f87171' : 'rgba(255,215,0,0.5)', background: isRecording ? 'rgba(239,68,68,0.3)' : 'rgba(255,215,0,0.2)', animation: isRecording ? 'pulse 2s infinite' : undefined } },
        isRecording ? h(Square, { size: 28, style: { color: '#f87171' } }) : h(Mic, { size: 28, style: { color: '#FFD700' } })
      )
    ),
    isRecording && h('p', { style: { textAlign: 'center', fontSize: '0.875rem', color: '#7B8CA8', marginBottom: '1rem', animation: 'pulse 2s infinite' } }, 'Hört zu... Sprich jetzt!'),
    transcript && !feedback && h('div', { style: { background: 'rgba(10,0,32,0.5)', border: '1px solid rgba(255,215,0,0.2)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '1rem', textAlign: 'center' } },
      h('p', { style: { fontSize: '0.75rem', color: '#7B8CA8', marginBottom: '0.25rem' } }, 'Du hast gesagt:'),
      h('p', { style: { color: '#F5E6D3', fontStyle: 'italic', fontFamily: "'EB Garamond',serif" } }, `"${transcript}"`)
    ),
    feedback && h('div', { style: { marginBottom: '1.25rem' } },
      h('div', { style: { background: 'rgba(10,0,32,0.5)', border: '1px solid rgba(255,215,0,0.2)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '0.75rem' } },
        h('div', { style: { display: 'flex', justifyContent: 'space-between', fontSize: '0.75rem', color: '#7B8CA8', marginBottom: '0.5rem' } },
          h('span', null, 'Aussprache-Score'),
          h('span', { style: { color: '#FFD700' } }, `${Math.round(feedback.similarity*100)}%`)
        ),
        h('div', { style: { width: '100%', height: '0.5rem', background: 'rgba(255,255,255,0.05)', borderRadius: '9999px', overflow: 'hidden' } },
          h('div', { style: { height: '100%', width: `${feedback.similarity*100}%`, background: feedback.similarity > 0.7 ? '#34d399' : feedback.similarity > 0.4 ? '#facc15' : '#f87171', transition: 'width 0.8s', borderRadius: '9999px' } })
        )
      ),
      feedback.missed.length > 0 && h('div', { style: { background: 'rgba(127,29,29,0.2)', border: '1px solid rgba(239,68,68,0.2)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '0.75rem' } },
        h('p', { style: { fontSize: '0.75rem', color: '#fca5a5', marginBottom: '0.5rem' } }, 'Fehlende Wörter:'),
        h('div', { style: { display: 'flex', flexWrap: 'wrap', gap: '0.5rem' } },
          feedback.missed.map((w, i) => h('span', { key: i, style: { padding: '0.25rem 0.5rem', background: 'rgba(127,29,29,0.3)', borderRadius: '0.25rem', color: '#fca5a5', fontSize: '0.875rem', fontStyle: 'italic' } }, w))
        )
      ),
      feedback.matched.length > 0 && h('div', { style: { background: 'rgba(6,78,59,0.2)', border: '1px solid rgba(16,185,129,0.2)', borderRadius: '0.75rem', padding: '1rem', marginBottom: '1rem' } },
        h('p', { style: { fontSize: '0.75rem', color: '#6ee7b7', marginBottom: '0.5rem' } }, 'Richtige Wörter:'),
        h('div', { style: { display: 'flex', flexWrap: 'wrap', gap: '0.5rem' } },
          feedback.matched.map((w, i) => h('span', { key: i, style: { padding: '0.25rem 0.5rem', background: 'rgba(6,78,59,0.3)', borderRadius: '0.25rem', color: '#6ee7b7', fontSize: '0.875rem', fontStyle: 'italic' } }, w))
        )
      ),
      h('div', { style: { display: 'flex', gap: '0.75rem' } },
        h('button', { onClick: () => { setFeedback(null); setTranscript(''); }, style: { flex: 1, padding: '0.75rem', background: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '0.5rem', color: '#7B8CA8', cursor: 'pointer', fontSize: '0.875rem' } }, 'Nochmal versuchen'),
        h('button', { onClick: next, style: { flex: 1, padding: '0.75rem', background: 'rgba(255,215,0,0.2)', border: '1px solid rgba(255,215,0,0.5)', borderRadius: '0.5rem', color: '#FFD700', fontWeight: '600', cursor: 'pointer' } },
          currentIdx < prompts.length - 1 ? 'Weiter →' : 'Abschließen')
      )
    )
  );
}

