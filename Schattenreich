// ─── BOSS BATTLE ──────────────────────────────────────────────
function BossBattle({ zoneId, onDefeat, onFail, onBack }) {
  const zone = getZoneById(zoneId);
  const [currentQ, setCurrentQ] = React.useState(0);
  const [hp, setHp] = React.useState(3);
  const [bossHp, setBossHp] = React.useState(10);
  const [score, setScore] = React.useState(0);
  const [selected, setSelected] = React.useState(null);
  const [phase, setPhase] = React.useState('battle');
  const scoreRef = React.useRef(score);
  scoreRef.current = score;   // keep ref synced with state

  if (!zone) return null;
  const questions = zone.boss;
  const q = questions[currentQ];

  const handleAnswer = idx => {
    if (selected !== null) return;
    setSelected(idx);
    const isCorrect = idx === q.correct;
    setTimeout(() => {
      if (isCorrect) {
        const newBossHp = bossHp - 1;
        setBossHp(newBossHp);
        setScore(s => {
          const updated = s + 20;
          scoreRef.current = updated;
          return updated;
        });
        if (newBossHp <= 0) {
          setPhase('victory');
          confetti({ particleCount: 200, spread: 100, origin: { y: 0.6 }, colors: ['#FFD700', '#FF4500', '#F5E6D3'] });
          setTimeout(() => onDefeat(scoreRef.current + 20), 3000);
          return;
        }
      } else {
        const newHp = hp - 1;
        setHp(newHp);
        if (newHp <= 0) {
          setPhase('defeat');
          setTimeout(() => onFail(), 3000);
          return;
        }
      }
      setCurrentQ(c => (c + 1) % questions.length);
      setSelected(null);
    }, 1000);
  };

  if (phase === 'victory') return h('div', { style: { maxWidth: '42rem', margin: '0 auto', textAlign: 'center', padding: '5rem 0' } },
    h(Trophy, { size: 96, style: { color: '#FFD700', margin: '0 auto 1.5rem' } }),
    h('h2', { style: { fontSize: '2.25rem', fontWeight: 'bold', color: '#FFD700', marginBottom: '1rem', fontFamily: "'Cinzel',serif" } }, 'Sieg!'),
    h('p', { style: { fontSize: '1.25rem', color: '#F5E6D3', marginBottom: '0.5rem' } }, `Zone ${zoneId} gemeistert`),
    h('p', { style: { color: '#FFD700', fontSize: '1.125rem' } }, `+${scoreRef.current} XP +150 Gold • Artefakt erhalten!`)
  );

  if (phase === 'defeat') return h('div', { style: { maxWidth: '42rem', margin: '0 auto', textAlign: 'center', padding: '5rem 0' } },
    h(Shield, { size: 80, style: { color: '#f87171', margin: '0 auto 1.5rem' } }),
    h('h2', { style: { fontSize: '1.875rem', fontWeight: 'bold', color: '#f87171', marginBottom: '1rem', fontFamily: "'Cinzel',serif" } }, 'Niederlage'),
    h('p', { style: { color: 'rgba(245,230,211,0.8)', marginBottom: '1rem' } }, 'Der Boss war zu stark. Versuche es später erneut.'),
    h('p', { style: { fontSize: '0.875rem', color: '#7B8CA8' } }, '-40 Gold Strafe')
  );

  return h('div', { style: { maxWidth: '42rem', margin: '0 auto' } },
    h('div', { style: { display: 'flex', alignItems: 'center', gap: '0.75rem', marginBottom: '1.5rem' } },
      h('button', { onClick: onBack, style: { padding: '0.5rem', background: 'none', border: 'none', cursor: 'pointer', color: '#7B8CA8' } }, h(ArrowLeft, { size: 20 })),
      h('div', { style: { flex: 1 } },
        h('h2', { style: { fontSize: '1.25rem', fontWeight: 'bold', color: '#f87171', fontFamily: "'Cinzel',serif" } }, 'Boss Kampf'),
        h('p', { style: { fontSize: '0.875rem', color: '#7B8CA8' } }, `Zone ${zoneId}: ${zone.name}`)
      ),
      h(Swords, { size: 24, style: { color: '#f87171' } })
    ),
    h('div', { style: { background: 'linear-gradient(135deg,#1a0a3e,#0d0221)', border: '1px solid rgba(239,68,68,0.3)', borderRadius: '1rem', padding: '1.5rem' } },
      h('div', { style: { display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '2rem' } },
        h('div', { style: { display: 'flex', gap: '0.25rem' } },
          [0,1,2].map(i => h(Heart, { key: i, size: 20, fill: i < hp ? '#ef4444' : 'none', style: { color: i < hp ? '#ef4444' : 'rgba(123,140,168,0.3)' } }))
        ),
        h('span', { style: { fontSize: '0.875rem', fontWeight: 'bold', color: '#FFD700', fontFamily: "'Cinzel',serif" } }, 'VS'),
        h('div', { style: { display: 'flex', alignItems: 'center', gap: '0.5rem' } },
          h('span', { style: { fontSize: '0.75rem', color: '#f87171' } }, 'Boss'),
          h('div', { style: { width: '8rem', height: '0.75rem', background: '#0a0020', borderRadius: '9999px', overflow: 'hidden', border: '1px solid rgba(239,68,68,0.3)' } },
            h('div', { style: { height: '100%', width: `${bossHp/10*100}%`, background: 'linear-gradient(to right,#dc2626,#f97316)', transition: 'width 0.5s', borderRadius: '9999px' } })
          )
        )
      ),
      h('div', { style: { textAlign: 'center', marginBottom: '1.5rem' } },
        h('p', { style: { fontSize: '0.875rem', color: '#7B8CA8', marginBottom: '0.75rem' } }, `Frage ${currentQ+1}`),
        h('p', { style: { fontSize: '1.25rem', fontWeight: 'bold', color: '#F5E6D3', marginBottom: '0.75rem' } }, q.q),
        q.de && h('button', { onClick: () => speak(q.de), style: { padding: '0.5rem', background: 'none', border: 'none', cursor: 'pointer', color: '#FFD700', display: 'inline-flex', alignItems: 'center', gap: '0.5rem' } },
          h(Volume2, { size: 16 }), h('span', { style: { fontSize: '0.75rem', fontStyle: 'italic', fontFamily: "'EB Garamond',serif" } }, q.de)
        )
      ),
      h('div', { style: { display: 'flex', flexDirection: 'column', gap: '0.75rem' } },
        q.opts.map((opt, i) => h('button', { key: i, onClick: () => handleAnswer(i), disabled: selected !== null, style: { width: '100%', padding: '1rem', borderRadius: '0.75rem', border: '1px solid', textAlign: 'left', cursor: selected !== null ? 'default' : 'pointer', borderColor: selected === null ? 'rgba(255,215,0,0.2)' : i === q.correct ? 'rgba(16,185,129,0.5)' : selected === i ? 'rgba(239,68,68,0.5)' : 'rgba(123,140,168,0.2)', background: selected === null ? 'rgba(10,0,32,0.5)' : i === q.correct ? 'rgba(6,78,59,0.3)' : selected === i ? 'rgba(127,29,29,0.3)' : 'rgba(10,0,32,0.3)', opacity: selected !== null && i !== q.correct && selected !== i ? 0.5 : 1, transition: 'all 0.3s' } },
          h('span', { style: { color: '#F5E6D3' } }, opt),
          selected !== null && i === q.correct && h(Check, { size: 20, style: { display: 'inline', marginLeft: '0.5rem', color: '#34d399' } }),
          selected === i && i !== q.correct && h(X, { size: 20, style: { display: 'inline', marginLeft: '0.5rem', color: '#f87171' } })
        ))
      ),
      h('div', { style: { marginTop: '1.5rem', textAlign: 'center' } },
        h('span', { style: { fontSize: '0.875rem', color: '#FFD700' } }, `Score: ${score}`)
      )
    )
  );
}

